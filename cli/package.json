{
  "name": "capstart",
  "version": "0.3.1",
  "description": "Add Capacitor to existing web framework projects.",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "bin": {
    "capstart": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "capacitor",
    "cli",
    "mobile",
    "nextjs",
    "nuxt",
    "react",
    "svelte",
    "sveltekit",
    "tanstack-start",
    "vite",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AdrienADV/capstart.git",
    "directory": "cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
