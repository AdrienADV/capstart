{
  "name": "capstart",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "vite preview",
    "preview": "bun run build && wrangler dev",
    "types:check": "fumadocs-mdx && tsc --noEmit",
